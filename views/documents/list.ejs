<%- include('../partials/header') %>
<div class="container">
  <div class="page-header">
    <h2>Documents</h2>
  </div>

  <div class="storage-indicator">
    <div class="storage-bar">
      <div class="storage-used" style="width: <%= Math.min((usedMB / maxMB) * 100, 100) %>%"></div>
    </div>
    <span class="storage-text">Available space: <%= (maxMB - usedMB).toFixed(1) %> MB (<%= usedMB %> used of <%= maxMB %> MB)</span>
  </div>

  <div class="content-tabs">
    <span class="content-tab active">Citizens Folders</span>
    <span class="content-tab">Common Folders</span>
  </div>

  <table class="data-table">
    <thead>
      <tr><th>Photo</th><th>Name</th><th>Room</th><th>Department</th><th>Documents</th><th>Actions</th></tr>
    </thead>
    <tbody>
      <% citizens.forEach(c => { %>
        <tr>
          <td>
            <% if (c.photo_path) { %>
              <img src="<%= basePath %><%= c.photo_path %>" class="photo-sm">
            <% } else { %>
              <div class="photo-sm-placeholder"><%= c.first_name.charAt(0) %><%= c.last_name.charAt(0) %></div>
            <% } %>
          </td>
          <td><a href="<%= basePath %>/documents/<%= c.id %>"><%= c.first_name %> <%= c.last_name %></a></td>
          <td><%= c.room_name || '-' %></td>
          <td><%= c.department_name || '-' %></td>
          <td><span class="badge"><%= c.doc_count %></span></td>
          <td><a href="<%= basePath %>/documents/<%= c.id %>" class="btn-sm">Open</a></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('../partials/footer') %>
