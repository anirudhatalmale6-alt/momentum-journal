<%- include('../partials/header') %>
<div class="container">
  <div class="page-header">
    <h2>Departments</h2>
    <a href="<%= basePath %>/organization" class="btn btn-secondary">Back to Organization</a>
  </div>

  <table class="data-table">
    <thead>
      <tr><th>Name</th><th>Description</th><th>Rooms</th><th>Citizens</th></tr>
    </thead>
    <tbody>
      <% departments.forEach(d => { %>
        <tr>
          <td><strong><%= d.name %></strong></td>
          <td><%= d.description || '-' %></td>
          <td><span class="badge"><%= d.room_count %></span></td>
          <td><span class="badge"><%= d.citizen_count %></span></td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <div class="card">
    <h3>Add Department</h3>
    <form method="POST" action="<%= basePath %>/organization/departments">
      <div class="form-row">
        <div class="form-group">
          <label>Name *</label>
          <input type="text" name="name" required>
        </div>
        <div class="form-group">
          <label>Description</label>
          <input type="text" name="description">
        </div>
      </div>
      <button type="submit" class="btn btn-primary">Add Department</button>
    </form>
  </div>
</div>
<%- include('../partials/footer') %>
