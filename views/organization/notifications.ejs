<%- include('../partials/header') %>
<div class="container">
  <div class="page-header">
    <h2>Notifications</h2>
    <a href="<%= basePath %>/organization" class="btn btn-secondary">Back to Organization</a>
  </div>

  <div class="notifications-list">
    <% if (notifications.length === 0) { %>
      <div class="empty-state"><p>No notifications.</p></div>
    <% } %>
    <% notifications.forEach(n => { %>
      <div class="notification-item <%= n.is_read ? 'read' : 'unread' %>">
        <div class="notification-content">
          <p><%= n.message %></p>
          <small class="text-muted"><%= n.created_at %></small>
        </div>
        <% if (!n.is_read) { %>
          <form method="POST" action="<%= basePath %>/organization/notifications/<%= n.id %>/read">
            <button type="submit" class="btn-xs">Mark Read</button>
          </form>
        <% } %>
      </div>
    <% }) %>
  </div>
</div>
<%- include('../partials/footer') %>
