<%- include('../partials/header') %>
<div class="container">
  <div class="page-header">
    <h2>Diary - <%= citizen.first_name %> <%= citizen.last_name %>
      <% if (citizen.room_name) { %><span class="text-muted">(<%= citizen.room_name %>)</span><% } %>
    </h2>
    <a href="/diary" class="btn btn-secondary">Back</a>
  </div>

  <!-- New Entry Form -->
  <div class="card">
    <h3>Add New Entry</h3>
    <form method="POST" action="/diary/<%= citizen.id %>">
      <div class="form-group">
        <label>Category</label>
        <select name="category">
          <option value="daily">Daily</option>
          <option value="health">Health</option>
          <option value="employment">Employment</option>
          <option value="education">Education</option>
          <option value="therapy">Therapy</option>
          <option value="planning">Planning</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div class="form-group">
        <label>Content</label>
        <textarea name="content" rows="4" required placeholder="Write diary entry..."></textarea>
      </div>
      <button type="submit" class="btn btn-primary">Save Entry</button>
    </form>
  </div>

  <!-- Entries List -->
  <div class="diary-entries">
    <% if (entries.length === 0) { %>
      <div class="empty-state"><p>No diary entries yet. Add the first entry above.</p></div>
    <% } %>
    <% entries.forEach(entry => { %>
      <div class="diary-entry" id="entry-<%= entry.id %>">
        <div class="entry-header">
          <div class="entry-meta">
            <span class="entry-date"><%= entry.created_at %></span>
            <span class="entry-author">by <%= entry.author_name || 'Unknown' %></span>
            <span class="category-badge category-<%= entry.category %>"><%= entry.category || 'daily' %></span>
          </div>
          <div class="entry-actions">
            <button onclick="toggleEdit(<%= entry.id %>)" class="btn-xs">Edit</button>
            <form method="POST" action="/diary/<%= citizen.id %>/<%= entry.id %>/delete" style="display:inline" onsubmit="return confirm('Delete this entry?')">
              <button type="submit" class="btn-xs btn-danger">Delete</button>
            </form>
          </div>
        </div>
        <div class="entry-content" id="content-<%= entry.id %>">
          <p><%= entry.content %></p>
        </div>
        <div class="entry-edit" id="edit-<%= entry.id %>" style="display:none">
          <form method="POST" action="/diary/<%= citizen.id %>/<%= entry.id %>/edit">
            <div class="form-group">
              <select name="category">
                <option value="daily" <%= entry.category === 'daily' ? 'selected' : '' %>>Daily</option>
                <option value="health" <%= entry.category === 'health' ? 'selected' : '' %>>Health</option>
                <option value="employment" <%= entry.category === 'employment' ? 'selected' : '' %>>Employment</option>
                <option value="education" <%= entry.category === 'education' ? 'selected' : '' %>>Education</option>
                <option value="therapy" <%= entry.category === 'therapy' ? 'selected' : '' %>>Therapy</option>
                <option value="planning" <%= entry.category === 'planning' ? 'selected' : '' %>>Planning</option>
                <option value="other" <%= entry.category === 'other' ? 'selected' : '' %>>Other</option>
              </select>
            </div>
            <textarea name="content" rows="4"><%= entry.content %></textarea>
            <div class="form-actions">
              <button type="submit" class="btn btn-primary btn-sm">Save</button>
              <button type="button" onclick="toggleEdit(<%= entry.id %>)" class="btn btn-secondary btn-sm">Cancel</button>
            </div>
          </form>
        </div>
        <% if (entry.updated_at !== entry.created_at) { %>
          <small class="text-muted">Last edited: <%= entry.updated_at %></small>
        <% } %>
      </div>
    <% }) %>
  </div>
</div>

<script>
function toggleEdit(id) {
  var content = document.getElementById('content-' + id);
  var edit = document.getElementById('edit-' + id);
  if (edit.style.display === 'none') {
    edit.style.display = 'block';
    content.style.display = 'none';
  } else {
    edit.style.display = 'none';
    content.style.display = 'block';
  }
}
</script>
<%- include('../partials/footer') %>
