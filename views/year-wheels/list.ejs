<%- include('../partials/header') %>
<div class="container">
  <div class="page-header">
    <h2>Year's Wheels</h2>
    <p class="page-desc">Annual planning overview for each citizen</p>
  </div>

  <table class="data-table">
    <thead>
      <tr><th>Photo</th><th>Name</th><th>Room</th><th>Department</th><th>Actions</th></tr>
    </thead>
    <tbody>
      <% citizens.forEach(c => { %>
        <tr>
          <td>
            <% if (c.photo_path) { %>
              <img src="<%= basePath %><%= c.photo_path %>" class="photo-sm">
            <% } else { %>
              <div class="photo-sm-placeholder"><%= c.first_name.charAt(0) %><%= c.last_name.charAt(0) %></div>
            <% } %>
          </td>
          <td><a href="<%= basePath %>/year-wheels/<%= c.id %>"><%= c.first_name %> <%= c.last_name %></a></td>
          <td><%= c.room_name || '-' %></td>
          <td><%= c.department_name || '-' %></td>
          <td><a href="<%= basePath %>/year-wheels/<%= c.id %>" class="btn-sm">View Year Wheel</a></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('../partials/footer') %>
